<!-- Admin Panel (Protected) -->
<div id="adminPanel" class="fixed inset-0 z-[100] hidden bg-black/50 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white max-w-6xl w-full max-h-[95vh] overflow-hidden rounded-3xl shadow-2xl border border-gray-200">
        <!-- Admin Header -->
        <div class="bg-gradient-to-r from-gray-900 to-gray-800 text-white p-6 border-b border-gray-700 sticky top-0 z-10">
            <div class="flex items-center justify-between">
