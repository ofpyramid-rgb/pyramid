                        </svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold">Admin Dashboard</h2>
                        <p class="text-gray-300 text-sm">Manage your Smart Living Store</p>
                    </div>
                </div>
                <div class="flex items-center space-x-3">
                    <span id="adminUserDisplay" class="px-3 py-1 bg-white/20 rounded-xl text-sm font-medium"></span>
                    <button id="logoutBtn" class="p-2 hover:bg-white/20 rounded-xl transition-all duration-200">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                    </button>
                    <button id="closeAdmin" class="p-2 hover:bg-white/20 rounded-xl transition-all duration-200">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="flex h-[calc(95vh-100px)] overflow-hidden">
            <!-- Sidebar -->
            <div class="w-64 bg-gray-50 border-r border-gray-200 p-6 overflow-y-auto">
                <div class="space-y-4">
                    <div class="text-center py-6 border-b border-gray-200">
                        <div class="w-16 h-16 bg-gradient-to-r from-green-500 to-green-600 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-lg">
                            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
                            </svg>
                        </div>
                        <div class="font-bold text-xl text-gray-900">Products</div>
                        <div class="text-2xl font-bold text-green-500" id="productsCountSidebar">0</div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4 text-center">
                        <button id="tabProducts" class="tab-btn active bg-white shadow-sm border border-gray-200 p-4 rounded-2xl hover:shadow-md transition-all duration-200 font-medium text-gray-900">
                            📦 Products
                        </button>
                        <button id="tabAnalytics" class="tab-btn bg-white shadow-sm border border-gray-200 p-4 rounded-2xl hover:shadow-md transition-all duration-200 font-medium text-gray-900">
                            📊
                        </button>
                    </div>
                    
                    <div class="space-y-2">
                        <button class="w-full bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white py-3 px-4 rounded-xl font-bold shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center space-x-2 text-sm">
                            ➕ Add New Product
                        </button>
                        <button class="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white py-3 px-4 rounded-xl font-bold shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center space-x-2 text-sm">
                            📤 Export Data
                        </button>
                        <button class="w-full bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white py-3 px-4 rounded-xl font-bold shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center space-x-2 text-sm">
                            🔄 Reset Demo
                        </button>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="flex-1 overflow-y-auto p-8">
                <!-- Products Tab -->
                <div id="tabContentProducts" class="tab-content active">
                    <!-- Add Product Form -->
                    <div class="bg-white border border-gray-200 rounded-3xl p-8 shadow-xl mb-12">
                        <h3 class="text-2xl font-bold text-gray-900 mb-6 flex items-center space-x-3">
                            <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                            <span>Add New Product</span>
                        </h3>
                        <form id="addProductForm" class="grid md:grid-cols-2 gap-8">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Product Title *</label>
                                <input type="text" id="productTitle" placeholder="e.g. Minimal Desk" class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg font-medium" required>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Price ($)*</label>
                                <input type="number" id="productPrice" placeholder="80" min="0" step="0.01" class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg font-medium" required>
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Product Image URL *</label>
                                <input type="url" id="productImage" placeholder="https://images.unsplash.com/..." class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg" required>
                                <div id="imagePreview" class="mt-4 w-32 h-32 bg-gray-200 rounded-2xl flex items-center justify-center text-gray-500 overflow-hidden"></div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Category *</label>
                                <select id="productCategory" class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg font-medium" required>
                                    <option value="">Select category</option>
                                    <option value="furniture">🛋️ Furniture</option>
                                    <option value="digital">📱 Digital</option>
                                    <option value="decor">🎨 Decor</option>
                                    <option value="lighting">💡 Lighting</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Room Type</label>
                                <select id="productRoom" class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg font-medium">
                                    <option value="">Any room</option>
                                    <option value="living">🛋️ Living Room</option>
                                    <option value="bedroom">🛏️ Bedroom</option>
                                    <option value="office">💻 Office</option>
                                    <option value="kitchen">🍳 Kitchen</option>
                                </select>
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Description</label>
                                <textarea id="productDescription" rows="4" placeholder="Describe your product (HTML supported)" class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg resize-vertical"></textarea>
                            </div>
                            <div class="md:col-span-2">
                                <label class="block text-sm font-semibold text-gray-700 mb-3">Benefits (one per line)</label>
                                <textarea id="productBenefits" rows="3" placeholder="e.g.&#10;Fits small spaces&#10;Easy assembly&#10;Premium materials" class="w-full p-4 rounded-2xl border border-gray-300 focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 text-lg resize-vertical"></textarea>
                            </div>
                            <div class="md:col-span-2 flex gap-4 pt-2">
                                <button type="submit" class="flex-1 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white py-4 px-8 rounded-2xl font-bold text-lg shadow-2xl hover:shadow-3xl transition-all duration-300 flex items-center justify-center space-x-3">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                                    </svg>
                                    <span>Add Product</span>
                                </button>
                                <button type="button" id="editCancelBtn" class="px-8 py-4 bg-gray-100 hover:bg-gray-200 text-gray-900 rounded-2xl font-bold text-lg shadow-lg hover:shadow-xl transition-all duration-300 hidden">
                                    Cancel Edit
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Products List -->
                    <div class="bg-white border border-gray-200 rounded-3xl shadow-xl overflow-hidden">
                        <div class="p-6 border-b border-gray-200 bg-gray-50">
                            <div class="flex items-center justify-between">
                                <h4 class="text-xl font-bold text-gray-900">All Products <span class="text-2xl text-green-500 ml-2" id="productsCount">0</span></h4>
                                <div class="flex items-center space-x-2">
                                    <select id="productsFilter" class="px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none">
                                        <option value="">All Categories</option>
